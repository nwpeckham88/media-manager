# Compose/runtime settings for Orange Pi target host

# Published HTTP port on target host
ORANGEPI_PUBLISHED_PORT=8080

# Host paths on target machine
HOST_STATE_DIR=./state
HOST_MEDIA_MOVIES_PATH=/srv/media/movies
HOST_MEDIA_TV_PATH=/srv/media/tv

# Runtime app config
MM_HOST=0.0.0.0
MM_PORT=8080
MM_LIBRARY_ROOTS=/media/movies:/media/tv
MM_STATE_DIR=/app/.mm-state
MM_FFMPEG_PATH=/usr/lib/jellyfin-ffmpeg/ffmpeg
MM_FFPROBE_PATH=/usr/lib/jellyfin-ffmpeg/ffprobe
MM_MEDIAINFO_PATH=/usr/bin/mediainfo

# Optional auth token for API
# MM_API_TOKEN=change-me
