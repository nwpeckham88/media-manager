# Server
MM_HOST=0.0.0.0
MM_PORT=8080

# Library management scope (path-list, ':' separated on Linux)
MM_LIBRARY_ROOTS=/mnt/media/movies:/mnt/media/tv

# Persistent state/audit directory
MM_STATE_DIR=.mm-state

# Optional API auth token (Bearer token). If unset, API runs without auth.
# MM_API_TOKEN=change-me

# Optional SQLite audit DB path (defaults to $MM_STATE_DIR/audit.sqlite3)
# MM_AUDIT_DB_PATH=.mm-state/audit.sqlite3

# Optional custom media toolchain binaries
# MM_FFMPEG_PATH=/usr/local/bin/jellyfin-ffmpeg
# MM_FFPROBE_PATH=/usr/local/bin/jellyfin-ffprobe
# MM_MEDIAINFO_PATH=/usr/bin/mediainfo

# Optional branding overrides
# MM_BRANDING_APP_NAME=Media Manager
# MM_BRANDING_SHORT_NAME=MM
# MM_BRANDING_LOGO_URL=/assets/logo.svg
# MM_BRANDING_BROWSER_TITLE_TEMPLATE={app_name}
# MM_BRANDING_ACCENT=#0f766e
# MM_BRANDING_ACCENT_CONTRAST=#f8fafc
